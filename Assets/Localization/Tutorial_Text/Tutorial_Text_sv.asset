  - m_Id: 687346335866880
    m_Localized: Skuggvandrarens kappa
    m_Metadata:
      m_Items: []
  - m_Id: 687596643540992
    m_Localized: "En antik artefakt som ger b\xE4raren telekinetiska krafter."
    m_Metadata:
      m_Items: []
  - m_Id: 8286608645152768
    m_Localized: "H\xE5ll {0} f\xF6r att ladda, sl\xE4pp sedan"
