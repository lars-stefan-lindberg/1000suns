  m_TableData:
  - m_Id: 667163726700544
    m_Localized: HMM...HMMMM...<shake>SITTER FAST</>...
    m_Metadata:
      m_Items: []
  - m_Id: 667384116404224
    m_Localized: "<color=#ad59c3><dangle>SOOT</></color> \xC4R <color=#ad59c3><dangle>SOOT</></color>.
      SKUGGA ICKE-SKUGGA."
    m_Metadata:
      m_Items: []
  - m_Id: 667403422785536
    m_Localized: "M\xC4NNISKA SN\xC4LL. M\xC4NNISKA NYFIKEN. KANSKE <wave>HJ\xC4LPSAM</>?"
    m_Metadata:
      m_Items: []
  - m_Id: 669376243032064
    m_Localized: "<color=#ad59c3><dangle>SOOT</></color> \xC4R LITEN. <shake>SITTER
      FAST</>. SITTER FAST INTE-BITA V\xC4N."
    m_Metadata:
      m_Items: []
  - m_Id: 667557794144256
    m_Localized: "Vem... vad \xE4r <wave>du</>?"
    m_Metadata:
      m_Items: []
  - m_Id: 667622747136000
    m_Localized: "Du \xE4r inte...<wave>farlig</>, v\xE4l?"
    m_Metadata:
      m_Items: []
  - m_Id: 667637527863296
    m_Localized: "Hmm..okay. Jag g\xF6r ett f\xF6rs\xF6k..."
    m_Metadata:
      m_Items: []
