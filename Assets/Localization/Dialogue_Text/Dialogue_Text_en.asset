    m_Metadata:
      m_Items: []
  - m_Id: 667557794144256
    m_Localized: Who... what are <wave>you</>?
    m_Metadata:
      m_Items: []
  - m_Id: 667622747136000
    m_Localized: You're not...<wave>dangerous</>, are you?
