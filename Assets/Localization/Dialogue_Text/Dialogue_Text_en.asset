  - m_Id: 667163726700544
    m_Localized: HMM...HMMMM...<shake>STUCK</>...
    m_Metadata:
      m_Items: []
  - m_Id: 667384116404224
    m_Localized: <color=#ad59c3><dangle>SOOT</></color> IS <color=#ad59c3><dangle>SOOT</></color>.
      SHADOW NOT-SHADOW.
    m_Metadata:
      m_Items: []
  - m_Id: 667403422785536
    m_Localized: HUMAN KIND. HUMAN CURIOUS. MAYBE <wave>HELPFUL</>?
    m_Metadata:
      m_Items: []
  - m_Id: 669376243032064
    m_Localized: <color=#ad59c3><dangle>SOOT</></color> IS SMALL. <shake>STUCK</>.
