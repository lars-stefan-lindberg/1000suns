  actor: 0
  paragraphEntries:
  - text: Why are we going down?
    portrait: {fileID: 21300000, guid: 7d0a7b656c6854d60ae63a769ef9d4f1, type: 3}
  - text: I don't want to go deeper...
    portrait: {fileID: 21300000, guid: 6193bcafdbf3745cdbf7c3b50215a165, type: 3}
  - text: I want out of here, right now!
    portrait: {fileID: 21300000, guid: 85345477026d44416a9d7489f727eada, type: 3}
  - text: I CAN'T TAKE THIS PLACE ANYMORE!
    portrait: {fileID: 21300000, guid: f7d29a528f0894458a9a43e9914f052d, type: 3}
